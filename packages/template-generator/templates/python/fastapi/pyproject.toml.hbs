[project]
name = "{{projectName}}"
version = "0.1.0"
description = "A FastAPI service scaffolded with Better-S-Stack"
readme = "README.md"
requires-python = ">=3.10"
dependencies = [
    "fastapi[standard]>=0.115",
]

[dependency-groups]
dev = [
    "pytest>=8",
]

[tool.pytest.ini_options]
pythonpath = ["."]
