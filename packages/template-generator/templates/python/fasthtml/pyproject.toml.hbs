[project]
name = "{{projectName}}"
version = "0.1.0"
description = "A FastHTML app scaffolded with Better-T-Stack"
readme = "README.md"
requires-python = ">=3.10"
dependencies = [
    "python-fasthtml>=0.6",
]

[dependency-groups]
dev = [
    "pytest>=8",
    "httpx>=0.27",
]

[tool.pytest.ini_options]
pythonpath = ["."]
