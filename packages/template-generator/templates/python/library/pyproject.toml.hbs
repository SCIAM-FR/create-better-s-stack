[project]
name = "{{projectName}}"
version = "0.1.0"
description = "A Python project scaffolded with Better-T-Stack"
readme = "README.md"
requires-python = ">=3.10"
dependencies = []

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{pyPackage projectName}}"]
