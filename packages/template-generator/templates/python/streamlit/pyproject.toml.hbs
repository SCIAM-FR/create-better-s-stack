[project]
name = "{{projectName}}"
version = "0.1.0"
description = "A Streamlit app scaffolded with Better-S-Stack"
readme = "README.md"
requires-python = ">=3.10"
dependencies = [
    "streamlit>=1.40",
]

[dependency-groups]
dev = [
    "pytest>=8",
]

[tool.pytest.ini_options]
pythonpath = ["."]
